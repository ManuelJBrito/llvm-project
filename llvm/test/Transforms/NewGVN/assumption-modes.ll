; NOTE: Assertions have been autogenerated by utils/update_test_checks.py
; Test the three assumption modes: optimistic, balanced, pessimistic.
;
; Optimistic and balanced start with all values in TOPClass (optimistic about values).
; Pessimistic starts with each value in its own singleton class.
; Balanced and pessimistic mark all blocks/edges reachable from the start.
; Optimistic discovers reachability during iteration.
;
; RUN: opt < %s -passes=newgvn -newgvn-assumption=optimistic -S | FileCheck %s --check-prefix=OPT
; RUN: opt < %s -passes=newgvn -newgvn-assumption=balanced -S | FileCheck %s --check-prefix=BAL
; RUN: opt < %s -passes=newgvn -newgvn-assumption=pessimistic -S | FileCheck %s --check-prefix=PESS

;; Cyclic phi equivalence: phi1 and phi2 in an irreducible cycle are equivalent
;; to %arg. Only optimistic discovers this (via iterative convergence).
;; Balanced and pessimistic do not (single-iteration).
define i32 @cyclic_phi(i32 %arg, i1 %cond) {
; OPT-LABEL: @cyclic_phi(
; OPT-NEXT:  bb:
; OPT-NEXT:    br i1 [[COND:%.*]], label [[BB2:%.*]], label [[BB1:%.*]]
; OPT:       bb1:
; OPT-NEXT:    br label [[BB2]]
; OPT:       bb2:
; OPT-NEXT:    br i1 [[COND]], label [[BB1]], label [[BB3:%.*]]
; OPT:       bb3:
; OPT-NEXT:    ret i32 0
;
; BAL-LABEL: @cyclic_phi(
; BAL-NEXT:  bb:
; BAL-NEXT:    br i1 [[COND:%.*]], label [[BB2:%.*]], label [[BB1:%.*]]
; BAL:       bb1:
; BAL-NEXT:    [[PHI1:%.*]] = phi i32 [ [[ARG:%.*]], [[BB:%.*]] ], [ [[PHI2:%.*]], [[BB2]] ]
; BAL-NEXT:    br label [[BB2]]
; BAL:       bb2:
; BAL-NEXT:    [[PHI2]] = phi i32 [ [[ARG]], [[BB]] ], [ [[PHI1]], [[BB1]] ]
; BAL-NEXT:    [[RESULT:%.*]] = sub i32 [[ARG]], [[PHI2]]
; BAL-NEXT:    br i1 [[COND]], label [[BB1]], label [[BB3:%.*]]
; BAL:       bb3:
; BAL-NEXT:    ret i32 [[RESULT]]
;
; PESS-LABEL: @cyclic_phi(
; PESS-NEXT:  bb:
; PESS-NEXT:    br i1 [[COND:%.*]], label [[BB2:%.*]], label [[BB1:%.*]]
; PESS:       bb1:
; PESS-NEXT:    [[PHI1:%.*]] = phi i32 [ [[ARG:%.*]], [[BB:%.*]] ], [ [[PHI2:%.*]], [[BB2]] ]
; PESS-NEXT:    br label [[BB2]]
; PESS:       bb2:
; PESS-NEXT:    [[PHI2]] = phi i32 [ [[ARG]], [[BB]] ], [ [[PHI1]], [[BB1]] ]
; PESS-NEXT:    [[RESULT:%.*]] = sub i32 [[ARG]], [[PHI2]]
; PESS-NEXT:    br i1 [[COND]], label [[BB1]], label [[BB3:%.*]]
; PESS:       bb3:
; PESS-NEXT:    ret i32 [[RESULT]]
;
bb:
  br i1 %cond, label %bb2, label %bb1
bb1:
  %phi1 = phi i32 [%arg, %bb], [%phi2, %bb2]
  br label %bb2
bb2:
  %phi2 = phi i32 [%arg, %bb], [%phi1, %bb1]
  %result = sub i32 %arg, %phi2
  br i1 %cond, label %bb1, label %bb3
bb3:
  ret i32 %result
}

;; Simple loop phi equivalence: m.0 and n.0 have the same initial value and
;; the same recurrence. Only optimistic discovers m.0 == n.0 (via iterative
;; convergence). Balanced and pessimistic do not (single-iteration).
define void @loop_phi_equiv(ptr %data) {
; OPT-LABEL: @loop_phi_equiv(
; OPT-NEXT:  bb:
; OPT-NEXT:    [[TMP:%.*]] = getelementptr inbounds i32, ptr [[DATA:%.*]], i64 3
; OPT-NEXT:    [[TMP1:%.*]] = load i32, ptr [[TMP]], align 4
