; OPT-NEXT:    ret void
;
; BAL-LABEL: @loop_phi_equiv(
; BAL-NEXT:  bb:
; BAL-NEXT:    [[TMP:%.*]] = getelementptr inbounds i32, ptr [[DATA:%.*]], i64 3
; BAL-NEXT:    [[TMP1:%.*]] = load i32, ptr [[TMP]], align 4
; BAL-NEXT:    [[TMP2:%.*]] = getelementptr inbounds i32, ptr [[DATA]], i64 4
; BAL-NEXT:    [[TMP3:%.*]] = load i32, ptr [[TMP2]], align 4
; BAL-NEXT:    br label [[LOOP:%.*]]
; BAL:       loop:
; BAL-NEXT:    [[M_0:%.*]] = phi i32 [ [[TMP3]], [[BB:%.*]] ], [ [[M_NEXT:%.*]], [[BODY:%.*]] ]
; BAL-NEXT:    [[N_0:%.*]] = phi i32 [ [[TMP3]], [[BB]] ], [ [[N_NEXT:%.*]], [[BODY]] ]
; BAL-NEXT:    [[I_0:%.*]] = phi i32 [ 0, [[BB]] ], [ [[I_NEXT:%.*]], [[BODY]] ]
; BAL-NEXT:    [[CMP:%.*]] = icmp slt i32 [[I_0]], [[TMP1]]
; BAL-NEXT:    br i1 [[CMP]], label [[BODY]], label [[EXIT:%.*]]
; BAL:       body:
; BAL-NEXT:    [[DIFF:%.*]] = sub nsw i32 [[M_0]], [[N_0]]
; BAL-NEXT:    store i32 [[DIFF]], ptr [[DATA]], align 4
; BAL-NEXT:    [[PTR1:%.*]] = getelementptr inbounds i32, ptr [[DATA]], i64 1
; BAL-NEXT:    [[INC:%.*]] = load i32, ptr [[PTR1]], align 4
; BAL-NEXT:    [[M_NEXT]] = add nsw i32 [[M_0]], [[INC]]
; BAL-NEXT:    [[N_NEXT]] = add nsw i32 [[N_0]], [[INC]]
; BAL-NEXT:    [[I_NEXT]] = add nsw i32 [[I_0]], 1
; BAL-NEXT:    br label [[LOOP]]
; BAL:       exit:
; BAL-NEXT:    ret void
;
; PESS-LABEL: @loop_phi_equiv(
; PESS-NEXT:  bb:
; PESS-NEXT:    [[TMP:%.*]] = getelementptr inbounds i32, ptr [[DATA:%.*]], i64 3
; PESS-NEXT:    [[TMP1:%.*]] = load i32, ptr [[TMP]], align 4
; PESS-NEXT:    [[TMP2:%.*]] = getelementptr inbounds i32, ptr [[DATA]], i64 4
; PESS-NEXT:    [[TMP3:%.*]] = load i32, ptr [[TMP2]], align 4
; PESS-NEXT:    br label [[LOOP:%.*]]
; PESS:       loop:
; PESS-NEXT:    [[M_0:%.*]] = phi i32 [ [[TMP3]], [[BB:%.*]] ], [ [[M_NEXT:%.*]], [[BODY:%.*]] ]
; PESS-NEXT:    [[N_0:%.*]] = phi i32 [ [[TMP3]], [[BB]] ], [ [[N_NEXT:%.*]], [[BODY]] ]
; PESS-NEXT:    [[I_0:%.*]] = phi i32 [ 0, [[BB]] ], [ [[I_NEXT:%.*]], [[BODY]] ]
; PESS-NEXT:    [[CMP:%.*]] = icmp slt i32 [[I_0]], [[TMP1]]
; PESS-NEXT:    br i1 [[CMP]], label [[BODY]], label [[EXIT:%.*]]
; PESS:       body:
; PESS-NEXT:    [[DIFF:%.*]] = sub nsw i32 [[M_0]], [[N_0]]
; PESS-NEXT:    store i32 [[DIFF]], ptr [[DATA]], align 4
; PESS-NEXT:    [[PTR1:%.*]] = getelementptr inbounds i32, ptr [[DATA]], i64 1
; PESS-NEXT:    [[INC:%.*]] = load i32, ptr [[PTR1]], align 4
; PESS-NEXT:    [[M_NEXT]] = add nsw i32 [[M_0]], [[INC]]
; PESS-NEXT:    [[N_NEXT]] = add nsw i32 [[N_0]], [[INC]]
; PESS-NEXT:    [[I_NEXT]] = add nsw i32 [[I_0]], 1
; PESS-NEXT:    br label [[LOOP]]
; PESS:       exit:
; PESS-NEXT:    ret void
;
bb:
  %tmp = getelementptr inbounds i32, ptr %data, i64 3
  %tmp1 = load i32, ptr %tmp, align 4
  %tmp2 = getelementptr inbounds i32, ptr %data, i64 4
  %tmp3 = load i32, ptr %tmp2, align 4
  br label %loop

loop:
  %m.0 = phi i32 [ %tmp3, %bb ], [ %m.next, %latch ]
  %n.0 = phi i32 [ %tmp3, %bb ], [ %n.next, %latch ]
  %i.0 = phi i32 [ 0, %bb ], [ %i.next, %latch ]
  %cmp = icmp slt i32 %i.0, %tmp1
  br i1 %cmp, label %body, label %exit

body:
  %diff = sub nsw i32 %m.0, %n.0
  store i32 %diff, ptr %data, align 4
  %ptr1 = getelementptr inbounds i32, ptr %data, i64 1
  %inc = load i32, ptr %ptr1, align 4
  %m.next = add nsw i32 %m.0, %inc
  %n.next = add nsw i32 %n.0, %inc
  br label %latch

latch:
  %i.next = add nsw i32 %i.0, 1
  br label %loop

exit:
  ret void
}
