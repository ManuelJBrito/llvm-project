; Transitive availability: the load in %merge is partially redundant.
; Both predecessors are unavailable directly, but the value is available
; transitively — through stores on each path.

; Diamond with stores on both sides → load fully eliminated (NumUnavail 2→0).
define i32 @diamond_stores(ptr %p, i1 %cond) {
; CHECK-LABEL: define i32 @diamond_stores(
; CHECK-SAME: ptr [[P:%.*]], i1 [[COND:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    store i32 1, ptr [[P]], align 4
; CHECK-NEXT:    br i1 [[COND]], label %[[LEFT:.*]], label %[[RIGHT:.*]]
; CHECK:       [[LEFT]]:
; CHECK-NEXT:    store i32 42, ptr [[P]], align 4
; CHECK-NEXT:    br label %[[MERGE:.*]]
; CHECK:       [[RIGHT]]:
; CHECK-NEXT:    store i32 99, ptr [[P]], align 4
; CHECK-NEXT:    br label %[[MERGE]]
; CHECK:       [[MERGE]]:
; CHECK-NEXT:    [[PHIOFOPS:%.*]] = phi i32 [ 99, %[[RIGHT]] ], [ 42, %[[LEFT]] ]
; CHECK-NEXT:    ret i32 [[PHIOFOPS]]
;
entry:
  store i32 1, ptr %p
  br i1 %cond, label %left, label %right

left:
  store i32 42, ptr %p
  br label %merge

right:
  store i32 99, ptr %p
  br label %merge

merge:
  %v = load i32, ptr %p
  ret i32 %v
}

