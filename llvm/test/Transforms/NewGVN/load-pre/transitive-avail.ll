}

; Three-way merge: stores on two paths, transparent on one.
define i32 @three_way_merge(ptr %p, i32 %sel) {
; CHECK-LABEL: define i32 @three_way_merge(
; CHECK-SAME: ptr [[P:%.*]], i32 [[SEL:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    store i32 0, ptr [[P]], align 4
; CHECK-NEXT:    switch i32 [[SEL]], label %[[PATH_C:.*]] [
; CHECK-NEXT:      i32 0, label %[[PATH_A:.*]]
; CHECK-NEXT:      i32 1, label %[[PATH_B:.*]]
; CHECK-NEXT:    ]
; CHECK:       [[PATH_A]]:
; CHECK-NEXT:    store i32 10, ptr [[P]], align 4
; CHECK-NEXT:    br label %[[MERGE:.*]]
; CHECK:       [[PATH_B]]:
; CHECK-NEXT:    store i32 20, ptr [[P]], align 4
; CHECK-NEXT:    br label %[[MERGE]]
; CHECK:       [[PATH_C]]:
; CHECK-NEXT:    br label %[[MERGE]]
; CHECK:       [[MERGE]]:
; CHECK-NEXT:    [[PHIOFOPS:%.*]] = phi i32 [ 20, %[[PATH_B]] ], [ 10, %[[PATH_A]] ], [ 0, %[[PATH_C]] ]
; CHECK-NEXT:    ret i32 [[PHIOFOPS]]
;
entry:
  store i32 0, ptr %p
  switch i32 %sel, label %path_c [
  i32 0, label %path_a
  i32 1, label %path_b
  ]

path_a:
  store i32 10, ptr %p
  br label %merge

path_b:
  store i32 20, ptr %p
  br label %merge

path_c:
  br label %merge

merge:
  %v = load i32, ptr %p
  ret i32 %v
}

; Deep chain: store is 3 blocks before merge, all transparent in between.
; Transitive walk should reach the store through intermediate blocks.
define i32 @deep_chain(ptr %p, i1 %c1, i1 %c2) {
; CHECK-LABEL: define i32 @deep_chain(
; CHECK-SAME: ptr [[P:%.*]], i1 [[C1:%.*]], i1 [[C2:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    store i32 55, ptr [[P]], align 4
; CHECK-NEXT:    br i1 [[C1]], label %[[BB2:.*]], label %[[SIDE:.*]]
; CHECK:       [[BB2]]:
; CHECK-NEXT:    br i1 [[C2]], label %[[BB3:.*]], label %[[SIDE]]
; CHECK:       [[BB3]]:
; CHECK-NEXT:    br label %[[MERGE:.*]]
; CHECK:       [[SIDE]]:
; CHECK-NEXT:    call void @may_clobber(ptr [[P]])
; CHECK-NEXT:    [[V_PRE:%.*]] = load i32, ptr [[P]], align 4
; CHECK-NEXT:    br label %[[MERGE]]
; CHECK:       [[MERGE]]:
; CHECK-NEXT:    [[V_PRE_PHI:%.*]] = phi i32 [ [[V_PRE]], %[[SIDE]] ], [ 55, %[[BB3]] ]
; CHECK-NEXT:    ret i32 [[V_PRE_PHI]]
;
entry:
  store i32 55, ptr %p
  br label %bb1

bb1:
  br i1 %c1, label %bb2, label %side

bb2:
  br i1 %c2, label %bb3, label %side

bb3:
  br label %merge

side:
  call void @may_clobber(ptr %p)
  br label %merge

merge:
  %v = load i32, ptr %p
  ret i32 %v
}

declare void @may_clobber(ptr)
