; CHECK-NEXT:    br label %[[MERGE:.*]]
; CHECK:       [[RIGHT]]:
; CHECK-NEXT:    br label %[[MERGE]]
; CHECK:       [[MERGE]]:
; CHECK-NEXT:    [[PHIOFOPS:%.*]] = phi i32 [ 1, %[[RIGHT]] ], [ 42, %[[LEFT]] ]
; CHECK-NEXT:    ret i32 [[PHIOFOPS]]
;
entry:
  store i32 1, ptr %p
